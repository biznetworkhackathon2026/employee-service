{
  "name": "employee-service",
  "version": "1.0.0",
  "description": "CAP CDS Employee Management Service",
  "engines": { "node": ">=18" },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "build": "cds build --production",
    "test": "jest --testEnvironment=node"
  },
  "dependencies": {
    "@sap/cds": "^8",
    "@sap/cds-dk": "^8",
    "@sap/xssec": "^3",
    "@cap-js/sqlite": "^1",
    "express": "^4",
    "passport": "^0.6"
  },
  "devDependencies": {
    "jest": "^29"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": { "url": ":memory:" }
      },
      "auth": {
        "kind": "xsuaa",
        "[development]": {
          "kind": "dummy"
        }
      },
      "notifications": {
        "kind": "alert-notification",
        "[development]": {
          "kind": "console"
        }
      }
    },
    "features": {
      "fetch_csrf": true
    }
  }
}
